# ==============================================
# Monitor Regulatorio ERP Farmacias
# Variables de entorno
# ==============================================

# Base de datos
# Nombre del archivo SQLite (en data/)
# Default: regulatory.db (local) | regulatory_deploy.db (Railway)
DB_NAME=regulatory.db

# Flask
# Clave secreta para sesiones Flask (generar con: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=cambiar-por-una-clave-segura

# Entorno: "development" habilita debug, cualquier otro valor = produccion
FLASK_ENV=production

# Token de autenticacion para endpoints admin (/pipeline/analizar, /api/webhook/test)
# Si no se configura, los endpoints quedan abiertos (solo para desarrollo local)
ADMIN_TOKEN=cambiar-por-un-token-seguro

# Webhooks
# URL del webhook para notificaciones (Make, Zapier, n8n, etc.)
WEBHOOK_URL=https://hook.us2.make.com/tu-webhook-url

# Secreto compartido para firmar payloads con HMAC-SHA256 (opcional)
WEBHOOK_SECRET=

# Dashboard
# URL publica del dashboard (para links en emails)
DASHBOARD_URL=https://web-production-fdec2.up.railway.app
