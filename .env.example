# ==============================================
# Monitor Regulatorio ERP Farmacias
# Variables de entorno
# ==============================================

# Base de datos
# PostgreSQL (produccion - Railway provee esta URL automaticamente)
# Si no se configura, usa SQLite como fallback (desarrollo local)
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Nombre del archivo SQLite para desarrollo local (en data/)
DB_NAME=regulatory.db

# Flask
# Clave secreta para sesiones Flask (generar con: python -c "import secrets; print(secrets.token_hex(32))")
FLASK_SECRET_KEY=cambiar-por-una-clave-segura

# Entorno: "development" habilita debug, cualquier otro valor = produccion
FLASK_ENV=production

# Autenticacion
# Email y contrasena del administrador inicial (se crea al iniciar la app)
ADMIN_EMAIL=admin@ejemplo.com
ADMIN_PASSWORD=cambiar-contrasena-segura

# Webhooks
# URL del webhook para notificaciones (Make, Zapier, n8n, etc.)
WEBHOOK_URL=https://hook.us2.make.com/tu-webhook-url

# Secreto compartido para firmar payloads con HMAC-SHA256 (opcional)
WEBHOOK_SECRET=

# Dashboard
# URL publica del dashboard (para links en emails)
DASHBOARD_URL=https://web-production-fdec2.up.railway.app

# Google Gemini (gratis - obtener en https://aistudio.google.com/apikey)
# Modelo: gemini-2.5-flash (15 RPM, 500 RPD, sin tarjeta de credito)
# Si no se configura, el sistema funciona sin analisis IA
GEMINI_API_KEY=tu-api-key-aqui
